---
import '../styles/global.css';
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Welcome Home</title>
	</head>
	<body class="bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] transition-colors duration-300 min-h-screen">
		
		<!-- Theme Dropdown -->
		<div class="fixed top-4 right-4 z-50">
			<div class="relative">
				<button
					id="theme-toggle"
					class="flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-bg-secondary)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-300 shadow-lg"
					aria-label="Select theme"
				>
					<svg id="current-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
					</svg>
					<span id="theme-label" class="text-sm font-medium">Light</span>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
				
				<div id="theme-dropdown" class="absolute right-0 mt-2 w-40 py-2 rounded-lg bg-[var(--color-bg-secondary)] shadow-xl opacity-0 invisible transition-all duration-200">
					<button
						data-theme="light"
						class="theme-option w-full flex items-center gap-3 px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white transition-colors"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
						<span>Light</span>
					</button>
					<button
						data-theme="dark"
						class="theme-option w-full flex items-center gap-3 px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white transition-colors"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
						</svg>
						<span>Dark</span>
					</button>
					<button
						data-theme="system"
						class="theme-option w-full flex items-center gap-3 px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white transition-colors"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						<span>System</span>
					</button>
				</div>
			</div>
		</div>

		<!-- Main Content -->
		<main class="min-h-screen flex flex-col items-center justify-center px-4">
			<div class="text-center space-y-6 animate-fade-in">
				<!-- Welcome Message -->
				<h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold">
					<span class="bg-gradient-to-r from-[var(--color-accent)] via-purple-500 to-pink-500 bg-clip-text text-transparent dark:from-indigo-400 dark:via-purple-400 dark:to-pink-400">
						Welcome Home
					</span>
				</h1>
				
				<!-- Subtitle -->
				<p class="text-lg sm:text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-md mx-auto">
					Your journey begins here. Build something amazing today.
				</p>
				
				<!-- Decorative Elements -->
				<div class="flex items-center justify-center gap-2 pt-4">
					<span class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
					<span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse" style="animation-delay: 0.2s"></span>
					<span class="w-2 h-2 rounded-full bg-pink-500 animate-pulse" style="animation-delay: 0.4s"></span>
				</div>
			</div>
		</main>

		<!-- Theme Toggle Script -->
		<script is:inline>
			const themeToggle = document.getElementById('theme-toggle');
			const themeDropdown = document.getElementById('theme-dropdown');
			const themeLabel = document.getElementById('theme-label');
			const currentIcon = document.getElementById('current-icon');
			const themeOptions = document.querySelectorAll('.theme-option');
			
			let currentTheme = localStorage.getItem('theme') || 'dark';
			let isDropdownOpen = false;

			const icons = {
				light: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />`,
				dark: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />`,
				system: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`
			};

			function setTheme(theme) {
				currentTheme = theme;
				localStorage.setItem('theme', theme);
				
				const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
				
				if (isDark) {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
				
				// Update button UI
				themeLabel.textContent = theme.charAt(0).toUpperCase() + theme.slice(1);
				currentIcon.innerHTML = icons[theme];
				
				// Update active state in dropdown
				themeOptions.forEach(opt => {
					const isActive = opt.dataset.theme === theme;
					opt.classList.toggle('bg-[var(--color-accent)]', isActive);
					opt.classList.toggle('text-white', isActive);
				});
			}

			function toggleDropdown() {
				isDropdownOpen = !isDropdownOpen;
				themeDropdown.classList.toggle('opacity-0', !isDropdownOpen);
				themeDropdown.classList.toggle('invisible', !isDropdownOpen);
				themeDropdown.classList.toggle('translate-y-2', !isDropdownOpen);
			}

			themeToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				toggleDropdown();
			});

			themeOptions.forEach(option => {
				option.addEventListener('click', () => {
					setTheme(option.dataset.theme);
					toggleDropdown();
				});
			});

			document.addEventListener('click', () => {
				if (isDropdownOpen) {
					toggleDropdown();
				}
			});

			// Listen for system theme changes
			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
				if (currentTheme === 'system') {
					setTheme('system');
				}
			});

			// Initialize theme
			setTheme(currentTheme);
		</script>

		<style>
			@keyframes fade-in {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			.animate-fade-in {
				animation: fade-in 0.8s ease-out forwards;
			}
		</style>
	</body>
</html>
